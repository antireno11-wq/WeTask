generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PRO
  ADMIN
}

enum BookingStatus {
  CREATED
  PENDING
  CONFIRMED
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTE
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  fullName            String
  phone               String?
  role                UserRole              @default(CUSTOMER)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  bookings            Booking[]             @relation("CustomerBookings")
  proBookings         Booking[]             @relation("ProBookings")
  addresses           Address[]
  sentMessages        Message[]             @relation("SenderMessages")
  reviewsGiven        Review[]              @relation("ReviewAuthor")
  professionalProfile ProfessionalProfile?
  payouts             Payout[]
}

model Category {
  id                    String    @id @default(cuid())
  slug                  String    @unique
  name                  String
  description           String?
  minHours              Int       @default(1)
  slotMinutes           Int       @default(60)
  basePlatformFeePct    Decimal   @default(0) @db.Decimal(5, 2)
  urgencyFeeClp         Int       @default(0)
  materialFeeDefaultClp Int       @default(0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  services              Service[]
}

model Service {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  description    String
  basePriceClp   Int
  durationMin    Int
  isActive       Boolean   @default(true)
  categoryId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
  slots          AvailabilitySlot[]
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId, isActive])
}

model ProfessionalProfile {
  id               String      @id @default(cuid())
  userId           String      @unique
  bio              String?
  isVerified       Boolean     @default(false)
  ratingAvg        Decimal     @default(0) @db.Decimal(3, 2)
  ratingsCount     Int         @default(0)
  coverageCity     String?
  coveragePostal   String?
  hourlyRateFromClp Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots            AvailabilitySlot[]
}

model AvailabilitySlot {
  id                  String              @id @default(cuid())
  professionalProfileId String
  serviceId           String?
  startsAt            DateTime
  endsAt              DateTime
  isAvailable         Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  service             Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([professionalProfileId, startsAt, isAvailable])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?
  street      String
  city        String
  postalCode  String
  region      String?
  country     String   @default("ES")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([userId, city])
}

model Booking {
  id                String        @id @default(cuid())
  customerId        String
  proId             String?
  serviceId         String
  addressId         String?
  status            BookingStatus @default(PENDING)
  scheduledAt       DateTime
  addressLine1      String
  comuna            String
  region            String
  city              String?
  postalCode        String?
  notes             String?
  hours             Int           @default(1)
  slotMinutes       Int           @default(60)
  autoAssign        Boolean       @default(false)
  hourlyPriceClp    Int           @default(0)
  subtotalClp       Int           @default(0)
  extrasTotalClp    Int           @default(0)
  platformFeeClp    Int           @default(0)
  totalPriceClp     Int
  paymentStatus     PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customer          User          @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Restrict)
  pro               User?         @relation("ProBookings", fields: [proId], references: [id], onDelete: SetNull)
  service           Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  address           Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  extras            BookingExtra[]
  messages          Message[]
  payment           Payment?
  payout            Payout?
  review            Review?
  disputes          DisputeTicket[]

  @@index([customerId, status])
  @@index([proId, status])
  @@index([scheduledAt, status])
}

model BookingExtra {
  id          String   @id @default(cuid())
  bookingId   String
  code        String
  name        String
  priceClp    Int
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Message {
  id          String   @id @default(cuid())
  bookingId   String
  senderId    String
  body        String
  imageUrl    String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender      User     @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Restrict)

  @@index([bookingId, createdAt])
}

model Payment {
  id                  String       @id @default(cuid())
  bookingId           String       @unique
  provider            String       @default("STRIPE")
  providerPaymentId   String?
  amountClp           Int
  platformFeeClp      Int          @default(0)
  status              PaymentStatus @default(PENDING)
  paidAt              DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  booking             Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payout {
  id                String       @id @default(cuid())
  bookingId         String       @unique
  proId             String
  amountClp         Int
  status            PayoutStatus @default(PENDING)
  requestedAt       DateTime     @default(now())
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  booking           Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  pro               User         @relation(fields: [proId], references: [id], onDelete: Restrict)
}

model Review {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  authorId          String
  rating            Int
  punctuality       Int?
  quality           Int?
  communication     Int?
  comment           String?
  providerReply     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author            User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([rating])
}

model DisputeTicket {
  id                String      @id @default(cuid())
  bookingId         String
  openedById        String?
  reason            String
  resolution        String?
  refundAmountClp   Int?
  status            TicketStatus @default(OPEN)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  booking           Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
}
